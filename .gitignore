AgenticAI4SCIENCE_pyrosetta_track/repos/ai4sci-kaeri/frontend/node_modules/

# Heavy reproducible binaries — Git LFS is NOT configured, so keep these ignored.
# (max-retention tracks text provenance: *.json/*.yaml/*.md; binaries below stay out)
**/*.pdb
**/*.cif
**/*.npz
**/*.npy
**/*.pkl
**/*.pt
**/*.pth
**/*.ckpt
**/*.safetensors
**/*.bin
**/*.a3m
**/*.gz
# Large run logs / monitors
**/gpu_monitor*.csv

