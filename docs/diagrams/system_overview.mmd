%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '14px' } } }%%
flowchart TB
    title["SSTR2 AI Co-Scientist System"]
    style title fill:none,stroke:none,color:#333,font-size:20px

    subgraph SILOA["Silo A — 3-ARM De Novo Pipeline"]
        direction TB
        A1["RFdiffusion\n(Backbone Generation)"]
        A2["ProteinMPNN\n(Sequence Design)"]
        A3["ESMFold\n(Structure Prediction)"]
        A4["DiffDock\n(Docking)"]
        A5["Boltz-2\n(Binding Affinity)"]
        A6["MolMIM\n(Molecular Optimization)"]
        A1 --> A2 --> A3 --> A4 --> A5 --> A6
    end

    subgraph SILOB["Silo B — PyRosetta Mutation-Dock Pipeline"]
        direction TB
        B1["SST-14 Reference\n(AGCKNFFWKTFTSC)"]
        B2["Guided / Random\nMutation"]
        B3["FlexPepDock\n(Parallel Refinement)"]
        B4["ddG Scoring\n& QC Gate"]
        B1 --> B2 --> B3 --> B4
    end

    subgraph AGENTS["5-Agent Agentic System"]
        direction LR
        AG1(["Planner"])
        AG2(["QC & Ranker"])
        AG3(["Diversity\nManager"])
        AG4(["Critic"])
        AG5(["Reporter"])
        AG1 --> AG2 --> AG3 --> AG4 --> AG5
        AG5 -.->|"feedback"| AG1
    end

    subgraph INFRA["Shared Infrastructure"]
        direction LR
        I1[("StatusEmitter\n(WebSocket)")]
        I2["FastAPI Backend\n(7 Routers)"]
        I3["React 19 Dashboard\n(5 Pages)"]
        I1 --> I2 --> I3
    end

    SILOA -->|"candidates"| AGENTS
    SILOB -->|"candidates"| AGENTS
    AGENTS -->|"results & events"| INFRA

    %% Styles
    style SILOA fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    style SILOB fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20
    style AGENTS fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#bf360c
    style INFRA fill:#f5f5f5,stroke:#616161,stroke-width:2px,color:#212121

    style A1 fill:#bbdefb,stroke:#1565c0,color:#0d47a1
