%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '13px' } } }%%
flowchart TB
    INPUT["Candidate Sequence"]

    subgraph STAGE1["Stage 1: Structural Rules (PASS / FAIL)"]
        direction LR
        R1["FWKT Motif\nConservation\n(pos 7-10)"]
        R2["K9-D122\nSalt Bridge"]
        R3["Cys3-Cys14\nDisulfide Bond"]
        R4["Phe6-Phe11\nAromatic Stacking"]
        R5["N-term Chelator\nCompatibility"]
    end

    subgraph STAGE2["Stage 2: Pharmacological Properties (13 Metrics)"]
        direction LR
        P1["GRAVY\n(Kyte-Doolittle)"]
        P2["Boman Index\n(kcal/mol)"]
        P3["Instability Index\n(Guruprasad)"]
        P4["Isoelectric\nPoint (pI)"]
        P5["Extinction\nCoefficient"]
        P6["Molecular\nWeight"]
        P7["Net Charge\n(pH 7.4)"]
        P8["Hydrophobic\nMoment"]
        P9["Amphipathicity\n(Eisenberg)"]
        P10["Wimley-White\nTransfer Energy"]
        P11["Aliphatic\nIndex"]
        P12["Aromaticity"]
        P13["Half-life\nEstimate"]
    end

    subgraph STAGE3["Stage 3: Statistical Validation"]
        direction LR
        S1["Rank Stability\n(across N trials)"]
        S2["Score Consistency\n(CV < threshold)"]
        S3["No-Dominance\nCheck"]
    end

    subgraph STAGE4["Stage 4: Radiopharmaceutical Assessment"]
        direction LR
        RP1["Chelator Compatibility\n(DOTA/NOTA for\n68Ga, 177Lu, 225Ac)"]
        RP2["Metabolic Stability\n(Protease Resistance)"]
        RP3["Renal Clearance\nProfile"]
    end

    DECISION{"Unified\nScore"}

    OUT_REC["RECOMMENDED\nProceed to Wet-Lab"]
    OUT_CON["CONDITIONAL\nFurther Optimization"]
    OUT_REJ["REJECTED\nDiscard"]

    INPUT --> STAGE1
    STAGE1 -->|"All PASS"| STAGE2
    STAGE1 -->|"Any FAIL"| OUT_REJ

    STAGE2 -->|"Numerical Values"| STAGE3
    STAGE3 --> STAGE4
    STAGE4 --> DECISION

    DECISION -->|"High confidence"| OUT_REC
    DECISION -->|"Marginal"| OUT_CON
    DECISION -->|"Poor profile"| OUT_REJ

    %% Styles
    style INPUT fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1

    style STAGE1 fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c
    style R1 fill:#ffcdd2,stroke:#c62828,color:#b71c1c
